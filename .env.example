# ══════════════════════════════════════════════
# Hybrid Engine Co. — Environment Variables
# ══════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# Supabase (Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ElevenLabs (Voiceover)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_MONTHLY_CHAR_LIMIT=100000
ELEVENLABS_VOICE_ID=default-voice-id

# Railway Runtime Budget
RAILWAY_MONTHLY_HOURS_LIMIT=500
RAILWAY_DAILY_HOURS_LIMIT=20

# YouTube Data API (uploads)
YOUTUBE_API_KEY=your-youtube-key
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# Stripe (payments + revenue)
STRIPE_SECRET_KEY=your-stripe-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# Gumroad (marketplace)
GUMROAD_ACCESS_TOKEN=your-gumroad-token

# OpenAI (content generation)
OPENAI_API_KEY=your-openai-key

# Orchestrator
ORCHESTRATOR_INTERVAL_MINUTES=30
MAX_CONCURRENT_PIPELINES=2
MAX_RETRIES_PER_AGENT=3
RETRY_BACKOFF_BASE_MS=1000

# Dashboard
DASHBOARD_POLL_INTERVAL_SECONDS=30

# Logging
LOG_LEVEL=info
